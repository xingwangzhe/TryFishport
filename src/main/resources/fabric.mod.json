{
  "schemaVersion": 1,
  "id": "tryfishport",
  "version": "${version}",
  "name": "TryFishport",
  "description": "a client mod for Minecraft that adds a func to the Fishport server",
  "authors": [
    "王兴家 <https://github.com/xingwangzhe>",
    "空城 離歌 <https://github.com/Kongchenglige>"
  ],
  "contact": {
    "homepage": "https://wiki.fishport.net",
    "sources": "https://github.com/xingwangzhe/TryFishport",
    "issues": "https://github.com/xingwangzhe/TryFishport/issues"
  },
  "license": "MIT",
  "icon": "assets/tryfishport/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "fun.xingwangzhe.tryfishport.client.TryfishportDataGenerator"
    ],
    "client": [
      "fun.xingwangzhe.tryfishport.client.TryfishportClient"
    ],
    "main": [
      "fun.xingwangzhe.tryfishport.Tryfishport"
    ]
  },
  "mixins": [
    "tryfishport.mixins.json",
    {
      "config": "tryfishport.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}